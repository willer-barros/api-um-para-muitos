generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Usuario{
  id String @id  @default(uuid())
  nome String
  email String  @unique
  senha String? //guarda a senha argon2id
  refreshToken String? //guarda token de 30 dias
  tarefas Tarefa[]
}

model Tarefa{
  id String @id  @default(uuid())
  titulo String
  descricao String?
  concluida Boolean @default(false)
  deletadoEm  DateTime?

  usuarioId String
  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
}